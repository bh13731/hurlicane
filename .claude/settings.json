{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node scripts/check-lock-hook.mjs"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node scripts/check-branch-hook.mjs"
          },
          {
            "type": "command",
            "command": "node scripts/check-prefix-hook.mjs"
          }
        ]
      }
    ]
  }
}
